---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../data/site";
---

<BaseLayout title="About" description="About William Pelrine — developer and photographer in Madison, WI.">
  <section class="page-hero">
    <h1>About</h1>
  </section>

  <section class="about-grid">
    <div class="about-copy">
      <p>
        William Pelrine is a software developer and photographer based in Madison, WI. He works
        primarily with functional programming, type systems, and developer tooling.
      </p>
      <p>
        Outside of code, he maintains a small photography practice — mostly street and landscape
        work shot around the Upper Midwest.
      </p>
      <p>
        This site collects longer writing, a few curated projects, and a selection of photographs.
        The best way to get in touch is <a href={`mailto:${siteConfig.email}`}>email</a>.
      </p>
    </div>

    <div class="about-media">
      <img
        src="/images/about/william-pelrine-portrait.jpg"
        alt="Portrait of William Pelrine"
        loading="eager"
      />
    </div>
  </section>
</BaseLayout>
