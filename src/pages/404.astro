---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Not Found" description="That page has drifted off the map.">
  <section class="page-hero">
    <p class="eyebrow">404</p>
    <h1>That page is not here.</h1>
    <p>
      The new site is still settling into shape. Head back home, or start with the blog and
      projects sections.
    </p>
    <div class="hero-actions">
      <a class="button-link is-primary" href="/">Go home</a>
      <a class="button-link is-secondary" href="/blog">Read the blog</a>
    </div>
  </section>
</BaseLayout>

