---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Not Found">
  <section class="page-hero">
    <h1>Page not found</h1>
    <p>Nothing here. Try heading back home or to the blog.</p>
    <div class="hero-actions" style="margin-top: 1.5rem;">
      <a class="button-link is-primary" href="/">Home</a>
      <a class="button-link is-secondary" href="/blog">Blog</a>
    </div>
  </section>
</BaseLayout>
