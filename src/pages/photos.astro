---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PhotoCard from "../components/PhotoCard.astro";

const photos = (await getCollection("photos")).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Photos" description="A small photo archive from Madison and beyond.">
  <section class="page-hero">
    <h1>Photos</h1>
    <p>Street and landscape work, mostly from the Upper Midwest.</p>
  </section>

  <section class="section-block">
    <div class="photo-grid">
      {photos.map((photo) => (
        <PhotoCard photo={photo} />
      ))}
    </div>
  </section>
</BaseLayout>
