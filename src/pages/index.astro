---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import PostCard from "../components/PostCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import PhotoCard from "../components/PhotoCard.astro";
import { siteConfig } from "../data/site";
import { url } from "../lib/url";

const byDateDesc = <T extends { data: { pubDate: Date } }>(a: T, b: T) =>
  b.data.pubDate.getTime() - a.data.pubDate.getTime();

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(byDateDesc);
const featuredPosts = posts.filter((post) => post.data.featured).slice(0, 3);
const projects = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);
const featuredProjects = projects.filter((project) => project.data.featured).slice(0, 3);
const photos = (await getCollection("photos")).sort((a, b) => a.data.order - b.data.order);
const featuredPhotos = photos.filter((photo) => photo.data.featured).slice(0, 3);
---

<BaseLayout>
  <section class="hero">
    <h1>{siteConfig.hero.headline}</h1>
    <p>{siteConfig.hero.body}</p>
    <div class="hero-actions">
      <a class="button-link is-primary" href={url(siteConfig.hero.primaryCta.href)}>
        {siteConfig.hero.primaryCta.label}
      </a>
      <a class="button-link is-secondary" href={url(siteConfig.hero.secondaryCta.href)}>
        {siteConfig.hero.secondaryCta.label}
      </a>
    </div>
  </section>

  <section class="section-block">
    <SectionHeading title="Writing" />
    <div class="card-grid">
      {featuredPosts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
    <p class="page-copy">
      <a class="divider-link" href={url("posts")}>All posts &rarr;</a>
    </p>
  </section>

  <section class="section-block">
    <SectionHeading title="Projects" />
    <div class="card-grid">
      {featuredProjects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>
  </section>

  <section class="section-block">
    <SectionHeading title="Photos" />
    <div class="photo-grid">
      {featuredPhotos.map((photo) => (
        <PhotoCard photo={photo} />
      ))}
    </div>
    <p class="page-copy">
      <a class="divider-link" href={url("photos")}>All photos &rarr;</a>
    </p>
  </section>
</BaseLayout>
